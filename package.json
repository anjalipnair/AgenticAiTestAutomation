{
  "name": "agenticaitestautomation",
  "version": "1.0.0",
  "description": "OpenCart Test Automation Framework with CI/CD Pipeline",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "test:demo": "TEST_ENV=demo playwright test",
    "test:staging": "TEST_ENV=staging playwright test",
    "test:local": "TEST_ENV=local playwright test",
    "test:production": "TEST_ENV=production playwright test",
    "test:login": "playwright test tests/login/",
    "test:security": "playwright test --grep \"security|injection|xss\"",
    "test:performance": "playwright test --grep \"performance|timing\"",
    "test:smoke": "playwright test tests/login/successful-login.spec.ts",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:cross-browser": "npm run test:chromium && npm run test:firefox && npm run test:webkit",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --workers=1",
    "test:ci": "CI=true playwright test --reporter=html,json,junit",
    "test:docker": "docker-compose up playwright-tests",
    "test:docker-demo": "docker-compose up demo-tests",
    "test:docker-staging": "docker-compose up staging-tests",
    "test:docker-security": "docker-compose up security-tests",
    "test:docker-performance": "docker-compose up performance-tests",
    "test:docker-cross-browser": "docker-compose up chromium-tests firefox-tests webkit-tests",
    "report:serve": "docker-compose up report-server",
    "install:browsers": "playwright install --with-deps",
    "codegen": "playwright codegen",
    "trace": "playwright show-trace",
    "lint:tests": "eslint tests/ --ext .ts",
    "format:tests": "prettier --write tests/",
    "clean:reports": "rm -rf playwright-report test-results",
    "setup:ci": "npm ci && npm run install:browsers",
    "generate-dashboard": "node scripts/generate-dashboard.js",
    "serve-dashboard": "cd dashboard && python3 -m http.server 8080 || python -m SimpleHTTPServer 8080",
    "dashboard": "npm run generate-dashboard && npm run serve-dashboard",
    "test:with-dashboard": "npm test && npm run generate-dashboard"
  },
  "keywords": ["playwright", "testing", "automation", "opencart", "ci/cd"],
  "author": "OpenCart Test Automation Team",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3"
  }
}
